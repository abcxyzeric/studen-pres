{"id":16,"name":"EV016","note":"<KNHShadow><HM8方向移動禁止>","pages":[{"conditions":{"actorId":1,"actorValid":false,"itemId":1,"itemValid":false,"selfSwitchCh":"A","selfSwitchValid":false,"switch1Id":1,"switch1Valid":false,"switch2Id":1,"switch2Valid":false,"variableId":1,"variableValid":false,"variableValue":0},"directionFix":false,"image":{"tileId":0,"characterName":"水泳部の男","direction":2,"pattern":0,"characterIndex":6},"list":[{"code":108,"indent":0,"parameters":["<Minimap:person0>"]},{"code":101,"indent":0,"parameters":["",0,0,2]},{"code":401,"indent":0,"parameters":["\"It's totally unrelated, but I feel like our school"]},{"code":401,"indent":0,"parameters":["principal has quite a lot of mysterious aspects.\""]},{"code":101,"indent":0,"parameters":["",0,0,2]},{"code":401,"indent":0,"parameters":["\"I understand that they seem capable, and it's not like I have any"]},{"code":401,"indent":0,"parameters":["complaints about the principal or anything, but there's just this"]},{"code":401,"indent":0,"parameters":["strange suspiciousness... It's like there's a strong sense of"]},{"code":401,"indent":0,"parameters":["mystery.\""]},{"code":101,"indent":0,"parameters":["",0,0,2]},{"code":401,"indent":0,"parameters":["\"I wonder if people like that actually have hidden sides――what kind of"]},{"code":401,"indent":0,"parameters":["things could be happening behind the scenes?\""]},{"code":101,"indent":0,"parameters":["",0,0,2]},{"code":401,"indent":0,"parameters":["\"Well, since she's the principal and all, I don't think something like"]},{"code":401,"indent":0,"parameters":["that would happen... But no one really knows the truth.\""]},{"code":101,"indent":0,"parameters":["",0,0,2]},{"code":401,"indent":0,"parameters":["\"Surprisingly, there might be some serious things happening..."]},{"code":401,"indent":0,"parameters":["hehehe.\""]},{"code":205,"indent":0,"parameters":[0,{"list":[{"code":16,"indent":null},{"code":0}],"repeat":false,"skippable":true,"wait":true}]},{"code":505,"i