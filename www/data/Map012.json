age":{"tileId":0,"characterName":"Evil","direction":2,"pattern":1,"characterIndex":3},"list":[{"code":108,"indent":0,"parameters":["<Minimap:person1>"]},{"code":111,"indent":0,"parameters":[1,20,0,85,1]},{"code":108,"indent":1,"parameters":["数値が85以上＝衣装が万全の状態"]},{"code":408,"indent":1,"parameters":["綺麗なまま"]},{"code":117,"indent":1,"parameters":[122]},{"code":101,"indent":1,"parameters":["",0,0,2]},{"code":401,"indent":1,"parameters":["\"Oh...? I sense an unsettling aura coming from you.\""]},{"code":101,"indent":1,"parameters":["",0,0,2]},{"code":401,"indent":1,"parameters":["\"If you'd like, shall we give it a try? Maybe we'll obtain"]},{"code":401,"indent":1,"parameters":["something like a signpost along the way.\""]},{"code":101,"indent":1,"parameters":["",0,0,2]},{"code":401,"indent":1,"parameters":["\"Well... Whether you believe it or not is up to you.\""]},{"code":101,"indent":1,"parameters":["",0,0,2]},{"code":401,"indent":1,"parameters":["\"What would you like to do?\""]},{"code":117,"indent":1,"parameters":[196]},{"code":117,"indent":1,"parameters":[222]},{"code":250,"indent":1,"parameters":[{"name":"Book1","volume":90,"pitch":100,"pan":0}]},{"code":102,"indent":1,"parameters":[["Receive a fortune-telling.","I refuse."],1,0,2,0]},{"code":402,"indent":1,"parameters":[0,"Receive a fortune-telling."]},{"code":108,"indent":2,"parameters":["選択肢ヘルプ"]},{"code":408,"indent":2,"parameters":["By getting a fortune-telling, some kind of event will occur."]},{"code":117,"indent":2,"parameters":[223]},{"code":117,"indent":2,"parameters":[197]},{"code":101,"indent":2,"parameters":["小坂井莉緒(制服)_表情一覧_1",4,0,2]},{"code":401,"indent":2,"parameters":["Rio"]},{"code":401,"indent":2,"parameters":["\"Well then, I have a small favor to ask.\""]},{"code":101,"indent":2,"parameters":["",0,0,2]},{"code":401,"indent":2,"parameters":["\"Understood. Shall we begin the divination right away?\""]},{"code":101,"indent":2,"parameters":["",0,0,2]},{"code":401,"indent":2,"parameters":["\"Let's s