ers":["小坂井莉緒(制服)_表情一覧_1",3,0,2]},{"code":401,"indent":0,"parameters":["Rio"]},{"code":401,"indent":0,"parameters":["\"It's great to be popular, but personally, I feel a strange"]},{"code":401,"indent":0,"parameters":["sense of discomfort.\""]},{"code":231,"indent":0,"parameters":[2,"三浦-大吾_立ち絵_ジャージとTシャツ姿-スッキリした顔",0,0,110,-40,100,100,255,0]},{"code":101,"indent":0,"parameters":["小坂井莉緒(制服)_表情一覧_1",6,0,2]},{"code":401,"indent":0,"parameters":["Rio"]},{"code":401,"indent":0,"parameters":["\"I may have misunderstood but... Could it be described as a"]},{"code":401,"indent":0,"parameters":["wicked feeling? But I also feel like it's something natural"]},{"code":401,"indent":0,"parameters":["for a man...\""]},{"code":101,"indent":0,"parameters":["小坂井莉緒(制服)_表情一覧_1",7,0,2]},{"code":401,"indent":0,"parameters":["Rio"]},{"code":401,"indent":0,"parameters":["\"Well, well, even if we think deeply, we won't understand. At"]},{"code":401,"indent":0,"parameters":["this point, nothing has caused any problems, and the content"]},{"code":401,"indent":0,"parameters":["of the request itself is serious.\""]},{"code":232,"indent":0,"parameters":[2,0,0,0,110,-40,100,100,0,0,60,true]},{"code":235,"indent":0,"parameters":[2]},{"code":101,"indent":0,"parameters":["小坂井莉緒(制服)_表情一覧_1",5,0,2]},{"code":401,"indent":0,"parameters":["Rio"]},{"code":401,"indent":0,"parameters":["\"After stamping \"Approved\" on this, let's move on to the next... The"]},{"code":401,"indent":0,"parameters":["next is a request for repair of school equipment, and the person in"]},{"code":401,"indent":0,"parameters":["charge is the Vice Principal.\""]},{"code":231,"indent":0,"parameters":[2,"山本-勉_立ち絵_スーツ姿-通常",0,0,120,-130,100,100,0,0]},{"code":232,"indent":0,"parameters":[2,0,0,0,120,-130,100,100,255,0,60,true]},{"code":101,"indent":0,"parameters":["小坂井莉緒(制服)_表情一覧_1",6,0,2]},{"code":401,"indent":0,"parameters":["Rio"]},{"code":401,"indent":0,"parameters":["\"Usually, he's very gentlemanly, but when he gets angry, it's really"]},{"code":401,"indent":0,"parameters":["tough.\""]},{"code":231,"indent":0,"parameters":[2,"山本-勉_立ち絵_スーツ姿-笑顔",0,0,120,-130,100,100,255,0]},{"code":101,"indent":0,"parameters":["小坂井莉緒(制服)_表情一覧_1",4,0,2]},{"code":401,"indent":0,"parameters":["Rio"]},{"code":401,"indent":0,"parameters":["\"There is no problem because it is not wrong as a teacher,"]},{"code":401,"indent":0,"parameters":["but just watching the way you get angry with a somewhat"]},{"code":401,"indent":0,"parameters":["sticky feeling causes mental damage... you know.\""]},{"code":231,"indent":0,"parameters":[2,"山本-勉_立ち絵_スーツ姿-企み顔",0,0,120,-130,100,100,255,0]},{"code":101,"indent":0,"parameters":["小坂井莉緒(制服)_表情一覧_1",3,0,2]},{"code":401,"indent":0,"parameters":["Rio"]},{"code":401,"indent":0,"parameters":["\"Other than that, she's a good teacher... But the Vice Principal also"]},{"code":401,"indent":0,"parameters":["gives off a strange vibe, similar to Mr. Miura. I wonder why?\""]},{"code":101,"indent":0,"parameters":["小坂井莉緒(制服)_表情一覧_1",3,0,2]},{"code":401,"indent":0,"parameters":["Rio"]},{"code":401,"indent":0,"parameters":["\"If someone tells me that I misunderstood, I can't say anything.\""]},{"code":232,"indent":0,"parameters":[2,0,0,0,120,-130,100,100,0,0,60,true]},{"code":235,"indent":0,"parameters":[2]},{"code":101,"indent":0,"parameters":["小坂井莉緒(制服)_表情一覧_1",7,0,2]},{"code":401,"indent":0,"parameters":["Rio"]},{"code":401,"indent":0,"parameters":["\"――Well, putting that aside, shall we move on with this, with"]},{"code":401,"indent":0,"parameters":["your approval?\""]},{"code":101,"indent":0,"parameters":["小坂井莉緒(制服)_表情一覧_1",6,0,2]},{"code":401,"indent":0,"parameters":["Rio"]},{"code":401,"indent":0,"parameters":["\"Let's see, next is... the principal, huh.\""]},{"code":231,"indent":0,"parameters":[2,"小田巻 三郎_スーツ姿 通常",0,0,100,-100,100,100,0,0]},{"code":232,"indent":0,"parameters":[2,0,0,0,100,-100,100,100,255,0,60,true]},{"code":101,"indent":0,"parameters":["小坂井莉緒(制服)_表情一覧_1",6,0,2]},{"code":401,"inden