08,"indent":0,"parameters":["<Minimap:person0>"]},{"code":205,"indent":0,"parameters":[0,{"list":[{"code":45,"parameters":["this._moveType = 0"],"indent":null},{"code":0}],"repeat":false,"skippable":true,"wait":false}]},{"code":505,"indent":0,"parameters":[{"code":45,"parameters":["this._moveType = 0"],"indent":null}]},{"code":111,"indent":0,"parameters":[1,20,0,85,1]},{"code":108,"indent":1,"parameters":["数値が85以上＝衣装が万全の状態"]},{"code":408,"indent":1,"parameters":["綺麗なまま"]},{"code":101,"indent":1,"parameters":["",0,0,2]},{"code":401,"indent":1,"parameters":["\"I prefer it to the hospital, but I also dislike the smell of"]},{"code":401,"indent":1,"parameters":["pharmacies.\""]},{"code":101,"indent":1,"parameters":["",0,0,2]},{"code":401,"indent":1,"parameters":["\"Well, I guess I'll just have to endure it for the sake of the"]},{"code":401,"indent":1,"parameters":["medicine.\""]},{"code":0,"indent":1,"parameters":[]},{"code":411,"indent":0,"parameters":[]},{"code":111,"indent":1,"parameters":[1,20,0,70,1]},{"code":108,"indent":2,"parameters":["数値が80以上＝アーマーブレイクの第一段階の状態"]},{"code":408,"indent":2,"parameters":["黒ストがところどころ破れている状態"]},{"code":101,"indent":2,"parameters":["",0,0,2]},{"code":401,"indent":2,"parameters":["\"I know it's best to get by without using medicine, but"]},{"code":401,"indent":2,"parameters":["since that's not possible, I have no choice but to endure.\""]},{"code":101,"indent":2,"parameters":["",0,0,2]},{"code":401,"indent":2,"parameters":["\"If there were magic in the world, it would be healed instantly,"]},{"code":401,"indent":2,"parameters":["wouldn't it?\""]},{"code":101,"indent":2,"parameters":["小坂井莉緒(制服)_表情一覧_1",3,0,2]},{"code":401,"indent":2,"parameters":["Rio"]},{"code":401,"indent":2,"parameters":["\"(Can't you just easily perform treatments like that in a"]},{"code":401,"indent":2,"parameters":["world like this?)\""]},{"code":0,"indent":2,"parameters":[]},{"code":411,"indent":1,"parameters":[]},{"code":111,"indent":2,"parameters":[1,20,0,50,1]