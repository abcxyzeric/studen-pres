{"id":3,"name":"EV003","note":"<KNHShadow>","pages":[{"conditions":{"actorId":1,"actorValid":false,"itemId":1,"itemValid":false,"selfSwitchCh":"A","selfSwitchValid":false,"switch1Id":1,"switch1Valid":false,"switch2Id":1,"switch2Valid":false,"variableId":1,"variableValid":false,"variableValue":0},"directionFix":true,"image":{"tileId":0,"characterName":"女子校生3","direction":2,"pattern":1,"characterIndex":1},"list":[{"code":108,"indent":0,"parameters":["<Minimap:person0>"]},{"code":108,"indent":0,"parameters":["ベンチに座っている"]},{"code":111,"indent":0,"parameters":[1,20,0,85,1]},{"code":108,"indent":1,"parameters":["数値が85以上＝衣装が万全の状態"]},{"code":408,"indent":1,"parameters":["綺麗なまま"]},{"code":101,"indent":1,"parameters":["",0,0,2]},{"code":401,"indent":1,"parameters":["\"It's nice to take a break in the classroom or somewhere like that,"]},{"code":401,"indent":1,"parameters":["but it's also quite comfortable to rest in the hallway or other"]},{"code":401,"indent":1,"parameters":["places♪\""]},{"code":0,"indent":1,"parameters":[]},{"code":411,"indent":0,"parameters":[]},{"code":111,"indent":1,"parameters":[1,20,0,70,1]},{"code":108,"indent":2,"parameters":["数値が80以上＝アーマーブレイクの第一段階の状態"]},{"code":408,"indent":2,"parameters":["黒ストがところどころ破れている状態"]},{"code":101,"indent":2,"parameters":["",0,0,2]},{"code":401,"indent":2,"parameters":["\"I don't think you see benches installed in the hallway at"]},{"code":401,"indent":2,"parameters":["other schools very often, do you?\""]},{"code":101,"indent":2,"parameters":["",0,0,2]},{"code":401,"indent":2,"parameters":["\"This school is really great in terms of facilities♪\""]},{"code":0,"indent":2,"parameters":[]},{"code":411,"indent":1,"parameters":[]},{"code":111,"indent":2,"parameters":[1,20,0,50,1]},{"code":108,"indent":3,"parameters":["数値が50以上＝アーマーブレイクの第二段階の状態"]},{"code":408,"indent":3,"parameters":["少し衣装が破れている"]},{"code":101,"indent":3,"parameters":["",0,0,2]},{"code":401,"indent":3,"parameters":["\"You... you have such a punk style. I-it's really cool!\""]},{"code":101,"indent":3,"parameters":["アーマーブレイク表情一覧_2",0,0,2]},{"code":401,"indent":3,"parameters":["Rio"]},{"code":401,"indent":3,"parameters":["\"You don't have to force yourself to compliment me, okay?\""]},{"code":101,"indent":3,"parameters":["",0,0,2]},{"code":401,"indent":3,"parameters":["\"Ah, ahahaha!\""]},{"code":0,"indent":3,"parameters":[]},{"code":411,"indent":2,"parameters":[]},{"code":111,"indent":3,"parameters":[1,20,0,20,1]},{"code":108,"indent":4,"parameters":["数値が50以上＝アーマーブレイクの第三段階の状態"]},{"code":408,"indent":4,"parameters":["かなりボロボロの状態"]},{"code":101,"indent":4,"parameters":["",0,0,2]},{"code":401,"indent":4,"parameters":["\"...So, the president also has various difficulties, huh.\""]},{"code":101,"indent":4,"parameters":["アーマーブレイク表情一覧_3",1,0,2]},{"code":401,"indent":4,"parameters":["Rio"]},{"code":401,"indent":4,"parameters":["\"(Are you worried about something strange happening?)\""]},{"code":0,"indent":4,"parameters":[]},{"code":411,"indent":3,"parameters":[]},{"code":108,"indent":4,"parameters":["数値が0以上＝アーマーブレイクの第四段階の状態"]},{"code":408,"indent":4,"parameters":["全裸"]},{"code":101,"indent":4,"parameters":["",0,0,2]},{"code":401,"indent":4,"parameters":["\"I-I didn't see anything. I haven't seen anything at all.\""]},{"code":101,"indent":4,"parameters":["小坂井莉緒(全裸)_表情一覧_1",4,0,2]},{"code":401,"indent":4,"parameters":["Rio"]},{"code":401,"indent":4,"parameters":["\"(Maybe I'm making you uncomfortable, huh?)\""]},{"code":0,"indent":4,"parameters":[]},{"code":412,"indent":3,"parameters":[]},{"code":0,"indent":3,"parameters":[]},{"code":412,"indent":2,"parameters":[]},{"code":0,"indent":2,"parameters":[]},{"code":412,"indent":1,"parameters":[]},{"code":0,"indent":1,"parameters":[]},{"code":412,"indent":0,"parameters":[]},{"code":0,"indent":0,"parameters":[]}],"moveFrequency":5,"moveRoute":{"list":[{"code":0,"parameters":[]}],"repeat":true,"skippable":false,"wait":false},"moveSpeed":3,"moveType":0,"priorityType":1,"stepAnime":false,"through":false,"trigger":0,"walkAnime":true}],"x":8,"y":8},
{"id":4,"name":"EV004","note":"<KNHShadow>","pages":[{"conditions":{"actorId":1,"actorValid":false,"itemId":1,"itemValid":false,"selfSwitchCh":"A","selfSwitchValid":false,"switch1Id":1,"switch1Valid":false,"switch2Id":1,"switch2Valid":false,"variableId":1,"variableValid":false,"variableValue":0},"directionFix":true,"image":{"tileId":0,"characterName":"女子校生4","direction":2,"pattern":1,"characterIndex":4},"list":[{"code":108,"indent":0,"parameters":["<Minimap:person0>"]},{"code":101,"indent":0,"parameters":["",0,0,2]},{"code":401,"indent":0,"parameters":["\"It's unavoidable that there are despicable men who engage in acts"]},{"code":401,"indent":0,"parameters":["such as groping and other wrongful actions, isn't it?\""]},{"code":101,"indent":0,"parameters":["",0,0,2]},{"code":401,"indent":0,"parameters":["\"I wish they would disappear if possible, but that's difficult, isn't"]},{"code":401,"indent":0,"parameters":["it?\""]},{"code":101,"indent":0,"parameters":["",0,0,2]},{"code":401,"indent":0,"parameters":["\"Please be careful, President. It wouldn't be a joke if you"]},{"code":401,"indent":0,"parameters":["were attacked by strange people!\""]},{"code":0,"indent":0,"parameters":[]}],"moveFrequency":5,"moveRoute":{"list":[{"code":0,"parameters":[]}],"repeat":true,"skippable":false,"wait":false},"moveSpeed":3,"moveType":0,"priorityType":1,"stepAnime":false,"through":false,"trigger":0,"walkAnime":true}],"x":17,"y":8},
