d":1,"switch2Valid":false,"variableId":1,"variableValid":false,"variableValue":0},"directionFix":false,"image":{"characterIndex":0,"characterName":"","direction":2,"pattern":0,"tileId":0},"list":[{"code":222,"indent":0,"parameters":[]},{"code":101,"indent":0,"parameters":["小坂井莉緒(制服)_表情一覧_1",4,0,2]},{"code":401,"indent":0,"parameters":["Rio"]},{"code":401,"indent":0,"parameters":["\"The sweets... They look incredibly delicious... Ahh...\""]},{"code":101,"indent":0,"parameters":["小坂井莉緒(制服)_表情一覧_1",2,0,2]},{"code":401,"indent":0,"parameters":["Rio"]},{"code":401,"indent":0,"parameters":["\"When I see things like this, I feel like eating... but I"]},{"code":401,"indent":0,"parameters":["have to exercise self-control!\""]},{"code":101,"indent":0,"parameters":["小坂井莉緒(制服)_表情一覧_1",4,0,2]},{"code":401,"indent":0,"parameters":["Rio"]},{"code":401,"indent":0,"parameters":["\"You really shouldn't eat too much, so please restrain yourself...\""]},{"code":205,"indent":0,"parameters":[13,{"list":[{"code":37,"indent":null},{"code":4,"indent":null},{"code":4,"indent":null},{"code":4,"indent":null},{"code":4,"indent":null},{"code":4,"indent":null},{"code":4,"indent":null},{"code":4,"indent":null},{"code":0}],"repeat":false,"skippable":true,"wait":true}]},{"code":505,"indent":0,"parameters":[{"code":37,"indent":null}]},{"code":505,"indent":0,"parameters":[{"code":4,"indent":null}]},{"code":505,"indent":0,"parameters":[{"code":4,"indent":null}]},{"code":505,"indent":0,"parameters":[{"code":4,"indent":null}]},{"code":505,"indent":0,"parameters":[{"code":4,"indent":null}]},{"code":505,"indent":0,"parameters":[{"code":4,"indent":null}]},{"code":505,"indent":0,"parameters":[{"code":4,"indent":null}]},{"code":505,"indent":0,"parameters":[{"code":4,"indent":null}]},{"code":101,"indent":0,"parameters":["",0,0,2]},{"code":401,"indent":0,"parameters":["\"Oh... Aren't you interested in our sweets? You're not purchasing"]},{"code":401,"indent":0,"parameters":["them?\""]},{"code":213,"indent":0,"parameters":[-1,1,false]},{"code":205,"indent":0,"parameters":[-1,{"list":[{"code":16,"indent":null},{"code":0}],"repeat":false,"skippable":true,"wait":true}]},{"code":505,"indent":0,"parameters":[{"code":16,"indent":null}]},{"code":101,"indent":0,"parameters":["小坂井莉緒(制服)_表情一覧_2",0,0,2]},{"code":401,"indent":0,"parameters":["Rio"]},{"code":401,"indent":0,"parameters":["\"T-That... It's just... the calorie restriction... ugh\""]},{"code":101,"indent":0,"parameters":["",0,0,2]},{"code":401,"indent":0,"parameters":["\"Oh, I see... Indeed, if you're a woman, you tend to worry"]},{"code":401,"indent":0,"parameters":["about the calorie intake of sweets, right?\""]},{"code":101,"indent":0,"parameters":["",0,0,2]},{"code":401,"indent":0,"parameters":["\"Ah, but it's a pity.\""]},{"code":101,"indent":0,"parameters":["小坂井莉緒(制服)_表情一覧_1",7,0,2]},{"code":401,"indent":0,"parameters":["Rio"]},{"code":401,"indent":0,"parameters":["\"What... What is disappointing?\""]},{"code":101,"indent":0,"parameters":["",0,0,2]},{"code":401,"indent":0,"parameters":["\"What? There's a little new confectionery right now. It's"]},{"code":401,"indent":0,"parameters":["the next flagship product that hasn't been released yet.\""]},{"code":101,"indent":0,"parameters":["",0,0,2]},{"code":401,"indent":0,"parameters":["\"I had been thinking about letting you try my confidently made"]},{"code":401,"indent":0,"parameters":["masterpiece sweets and asking for your opinion...but oh well.\""]},{"code":101,"indent":0,"parameters":["小坂井莉緒(制服)_表情一覧_1",7,0,2]},{"code":401,"indent":0,"parameters":["Rio"]},{"code":401,"indent":0,"parameters":["\"S-Shishi, a new sweet treat?!\""]},{"code":101,"indent":0,"parameters":["",0,0,2]},{"code":401,"indent":0,"parameters":["\"Yes. However, if you're in the middle of calorie restriction, you"]},{"code":401,"indent":0,"parameters":["should give up-\""]},{"code":101,"indent":0,"parameters":["小坂井莉緒(制服)_表情一覧_1",2,0,2]},{"code":401,"indent":0,"parameters":["Rio"]},{"code":401,"indent":0,"parameters":["\"I will eat! Please let me eat!\""]},{"code":101,"indent":0,"parameters":["",0,0,2]},{"code":401,"indent":0,"parameters":["\"Oh, my. That's impressive enthusiasm... Is it really okay to agree so"]},{"code":401,"indent":0,"parameters":["easily?\""]},{"code":101,"indent":0,"parameters":["",0,0,2]},{"code":401,"indent":0,"parameters":["\"Asking for your opinion is one thing, but is it really okay to also"]},{"code":401,"indent":0,"parameters":["have you change into a special costume - a leotard - and do naughty"]},{"code":401,"indent":0,"parameters":["things?\""]},{"code":101,"indent":0,"parameters":["小坂井莉緒(制服)_表情一覧_2",0,0,2]},{"code":401,"indent":0,"parameters":["Rio"]},{"code":401,"indent":0,"parameters":["\"It's for a new confectionery!\""]},{"code":101,"indent":0,"parameters":["小坂井莉緒(制服)_表情一覧_1",2,0,2]},{"code":401,"indent":0,"parameters":["Rio"]},{"code":401,"indent":0,"parameters":["\"If you let it escape here, you might not be able to eat for"]},{"code":401,"indent":0,"parameters":["a while!\""]},{"code":101,"indent":0,"parameters":["",0,0,2]},{"code":401,"indent":0,"parameters":["\"Muhoho... That's a good mindset. Shall we move over there"]},{"code":401,"indent":0,"parameters":["and enjoy ourselves in various ways?\""]},{"code":101,"indent":0,"parameters":["",0,0,2]},{"code":401,"indent":0,"parameters":["\"Sweets and romance...\""]},{"code":221,"indent":0,"parameters":[]},{"code":101,"indent":0,"parameters":["",0,0,2]},{"code":401,"indent":0,"parameters":["Rio is choosing an option that is normally unthinkable. If it were any"]},{"code":401,"indent":0,"parameters":["other situation, she would definitely refuse adamantly."]},{"code":101,"indent":0,"parameters":["",0,0,2]},{"code":401,"indent":0,"parameters":["But this time, I encountered a difficult opponent. A Western-style"]},{"code":401,"indent":0,"parameters":["confectionery shop that sells my favorite sweets. The new"]},{"code":401,"indent":0,"parameters":["confectionery that is planned to be sold there."]},{"code":101,"indent":0,"parameters":["",0,0,2]},{"code":401,"indent":0,"parameters":["If presented with this, even level-headed Rio wouldn't be able to make"]},{"code":401,"indent":0,"parameters":["a rational decision. In a state of slight confusion, she would end up"]},{"code":401,"indent":0,"parameters":["consenting to a sexual act."]},{"code":117,"indent":0,"parameters":[21]},{"code":230,"indent":0,"parameters":[40]},{"code":250,"indent":0,"parameters":[{"name":"SE_move01","volume":90,"pitch":90,"pan":0}]},{"code":117,"indent":0,"parameters":[1]},{"code":201,"indent":0,"parameters":[0,3,33,29,2,0]},{"code":356,"indent":0,"parameters":["audiosource bgs 3"]},{"code":117,"indent":0,"parameters":[121]},{"code":222,"indent":0,"parameters":[]},{"code":213,"indent":0,"parameters":[-1,3,true]},{"code":101,"indent":0,"parameters":["小坂井莉緒(制服)_表情一覧_1",1,0,2]},{"code":401,"indent":0,"parameters":["Rio"]},{"code":401,"indent":0,"parameters":["\"Aahhh... I'm completely satisfied ♪\""]},{"code":101,"indent":0,"parameters":["小坂井莉緒(制服)_表情一覧_1",4,0,2]},{"code":401,"indent":0,"parameters":["Rio"]},{"code":401,"indent":0,"parameters":["\"The naughty act was something, but it was the best sweets to"]},{"code":401,"indent":0,"parameters":["the point that I didn't mind...\""]},{"code":101,"indent":0,"parameters":["小坂井莉緒(制服)_表情一覧_2",0,0,2]},{"code":401,"indent":0,"parameters":["Rio"]},{"code":401,"indent":0,"parameters":["\"Well, um... considering that, I guess this time it can't be"]},{"code":401,"indent":0,"parameters":["helped, right? I didn't do anything wrong!\""]},{"code":117,"indent":0,"parameters":[7]},{"code":122,"indent":0,"parameters":[148,148,1,0,1]},{"code":122,"indent":0,"parameters":[151,151,1,0,5]},{"code":122,"indent":0,"parameters":[152,152,1,0,1]},{"code":122,"indent":0,"parameters":[157,157,1,0,1]},{"code":122,"indent":0,"parameters":[159,159,1,0,1]},{"code":122,"indent":0,"parameters":[193,193,1,0,1]},{"code":117,"indent":0,"parameters":[254]},{