["",0,0,2]},{"code":401,"indent":4,"parameters":["\"I really wish you would cut me some slack.\""]},{"code":0,"indent":4,"parameters":[]},{"code":411,"indent":3,"parameters":[]},{"code":111,"indent":4,"parameters":[0,5,0]},{"code":101,"indent":5,"parameters":["",0,0,2]},{"code":401,"indent":5,"parameters":["\"It's better not to get too close to the remains of the factory. From"]},{"code":401,"indent":5,"parameters":["the looks of it, there seems to be a gathering of shady individuals.\""]},{"code":101,"indent":5,"parameters":["",0,0,2]},{"code":401,"indent":5,"parameters":["\"I don't know why they've gathered, but it definitely seems"]},{"code":401,"indent":5,"parameters":["dangerous.\""]},{"code":0,"indent":5,"parameters":[]},{"code":411,"indent":4,"parameters":[]},{"code":111,"indent":5,"parameters":[0,4,0]},{"code":101,"indent":6,"parameters":["",0,0,2]},{"code":401,"indent":6,"parameters":["\"I heard a rumor that some rough-looking people have gathered in the"]},{"code":401,"indent":6,"parameters":["abandoned warehouse, but I hope they stop causing trouble.\""]},{"code":101,"indent":6,"parameters":["",0,0,2]},{"code":401,"indent":6,"parameters":["\"If something strange happens, I won't be able to go on long trips or"]},{"code":401,"indent":6,"parameters":["anything.\""]},{"code":0,"indent":6,"parameters":[]},{"code":411,"indent":5,"parameters":[]},{"code":101,"indent":6,"parameters":["",0,0,2]},{"code":401,"indent":6,"parameters":["\"I wonder what will start when delinquents gather at the abandoned"]},{"code":401,"indent":6,"parameters":["hospital.\""]},{"code":101,"indent":6,"parameters":["",0,0,2]},{"code":401,"indent":6,"parameters":["\"Honestly, I don't have a good feeling about it.\""]},{"code":0,"indent":6,"parameters":[]},{"code":412,"indent":5,"parameters":[]},{"code":0,"indent":5,"parameters":[]},{"code":412,"indent":4,"parameters":[]},{"code":0,"indent":4,"parameters":[]},{"code":412,"indent":3,"parameters":[]},{"code":0,"indent":3,"parameters":[]},{"c